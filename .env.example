# Token del bot de Discord (del Discord Developer Portal)
DISCORD_BOT_TOKEN=

# ID de la aplicación Discord (Client ID del bot)
DISCORD_CLIENT_ID=

# ID del servidor Discord donde opera el bot
DISCORD_GUILD_ID=

# Shared secret para autenticarse con el backend (mismo valor que INTERNAL_SECRET del backend)
INTERNAL_SECRET=

# URL base del backend (localhost porque están en el mismo Droplet)
BACKEND_URL=http://localhost:3000

# ID del Google Spreadsheet donde se registran los clockin/clockout
GOOGLE_SHEETS_SPREADSHEET_ID=

# Ruta absoluta al JSON de credenciales del service account de Google Cloud
# El service account debe tener permiso de Editor en el spreadsheet
# Ej. en el Droplet: /etc/iul-discord-bot-sa.json (permisos 600, propietario iul)
GOOGLE_SERVICE_ACCOUNT_JSON=/etc/iul-discord-bot-sa.json

# Entorno
NODE_ENV=production
